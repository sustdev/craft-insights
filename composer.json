{
    "name": "sustdev/craft-insights",
    "description": "Exposes a metrics endpoint (queue health, form submissions, Freeform errors) for the Sustdev Insights monitoring platform.",
    "type": "craft-plugin",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "sustdev\\insights\\": "src/"
        }
    },
    "extra": {
        "handle": "insights",
        "name": "Sustdev Insights",
        "developer": "sustdev",
        "documentationUrl": "https://github.com/sustdev/craft-insights",
        "class": "sustdev\\insights\\Plugin"
    }
}
